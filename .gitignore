# Large downloaded TTS model DATA (install per-machine via setup/*.bat).
# Only the helper .py files at repo root are committed; model weights are not.
VoiceModules/PiperTTS/
VoiceModules/Qwen3-TTS/
VoiceModules/KokoroTTS/
VoiceModules/NeuTTS/
VoiceModules/pytorch/
*.onnx
*.pt
VoiceModules/**/*.bin

# Whisper model weights (faster-whisper) — copied per-machine, too big for git.
# The _whisper_word_timestamps.py helper auto-detects them in this folder.
models/whisper/

# pyannote diarization models (multi-speaker dubbing) — copied per-machine.
models/pyannote/

# Dubbing installer artifacts — large per-machine data, NOT committed.
# The offline model bundle (whisper ~1.6 GB, pyannote ~32 MB) and the pip
# wheelhouse travel with the folder-copy to a new PC, not through git.
# Only the small demucs weight (~81 MB) is tracked.
setup/models/whisper/
setup/models/pyannote/
setup/wheels/
setup/dub_venv/
!setup/models/demucs/
!setup/models/demucs/*.th
setup/wheels/
setup/dub_venv/

# User content
Background music/
VoiceModules/New folder/

# Windows reserved device name - can't be deleted via normal filesystem ops
nul

# User settings (personal, per-machine configuration)
overlay_settings.json
processing_paths.json

# Shell-typo artifacts — 0-byte files created by accidental output redirection
